# ============================================================
# GapSight backend environment configuration
# ------------------------------------------------------------
# Copy this file to `.env` and fill in real values for local
# development. Do NOT commit secrets to source control.
# ============================================================

# --- Application ---
APP_NAME=GapSight
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- CORS (comma-separated list of allowed origins) ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Google Gemini (LLM + embeddings) ---
# Get a key from https://aistudio.google.com/apikey (free tier available)
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Vector DB (Chroma) ---
VECTOR_DB_PROVIDER=chroma
VECTOR_DB_PATH=./.chroma
VECTOR_DB_COLLECTION=gapsight_claims

# --- Prior art search ---
PATENT_API_BASE_URL=https://api.patentsview.org/patents/query
PATENT_API_KEY=replace-me

# --- Upload limits ---
MAX_UPLOAD_MB=25
